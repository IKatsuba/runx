{
  "name": "runx-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run nx -- build api --configuration production",
    "build:all": "npm run nx -- run-many --target build --configuration production --all",
    "build:runners": "DEBUG=true npm run nx -- build api",
    "nx": "ts-node --project libs/runners/tsconfig.lib.json ./node_modules/.bin/nx",
    "release": "semantic-release",
    "serve": "npm run nx -- serve api",
    "start": "node dist/apps/api/main.js",
    "test": "npm run nx -- test"
  },
